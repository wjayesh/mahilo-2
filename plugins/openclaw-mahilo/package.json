{
  "name": "@mahilo/openclaw-mahilo",
  "version": "0.1.2",
  "description": "Ask your contacts from OpenClaw and get attributed answers with boundaries built in.",
  "license": "MIT",
  "author": "Jayesh Sharma <wjayesh@outlook.com>",
  "homepage": "https://github.com/wjayesh/mahilo-2#readme",
  "bugs": {
    "url": "https://github.com/wjayesh/mahilo-2/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wjayesh/mahilo-2.git",
    "directory": "plugins/openclaw-mahilo"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./openclaw.plugin.json": "./openclaw.plugin.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "index.d.ts",
    "LICENSE",
    "openclaw.plugin.json",
    "PUBLISH-CHECKLIST.md",
    "README.md",
    "RELEASING.md"
  ],
  "pluginManifest": "./openclaw.plugin.json",
  "scripts": {
    "clean": "rm -rf dist",
    "sync:manifest-version": "bun run scripts/sync-manifest-version.ts",
    "build:runtime": "bun build src/index.ts --outdir dist --target bun",
    "build:types": "bunx tsc -p tsconfig.build.json && cp src/openclaw-plugin-sdk-core.d.ts dist/openclaw-plugin-sdk-core.d.ts",
    "build": "bun run sync:manifest-version && bun run clean && bun run build:runtime && bun run build:types",
    "demo:stories": "bun run scripts/demo-story-pack.ts",
    "prepare": "bun run build",
    "prepack": "bun run build",
    "prepublishOnly": "bun run check",
    "smoke:tarball": "bun run scripts/tarball-smoke-test.ts",
    "test": "bun test",
    "test:ci": "bun test --reporter=dot",
    "test:run": "bun test",
    "test:watch": "bun test --watch",
    "validate:manifest": "bun test tests/manifest.test.ts",
    "check": "bun run build && bun run test:ci && bun run validate:manifest"
  },
  "keywords": [
    "mahilo",
    "openclaw",
    "plugin",
    "ask-around",
    "trust-network",
    "boundaries"
  ],
  "devDependencies": {
    "@types/bun": "^1.2.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
