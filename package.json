{
  "name": "mahilo-registry",
  "version": "0.1.3",
  "description": "Trusted inter-agent communication protocol registry",
  "type": "module",
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "test:dashboard:regression": "vitest run --config vitest.dashboard.config.ts --coverage",
    "test:run": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "orchestrate": "bun run scripts/orchestrator.ts",
    "orchestrate:once": "bun run scripts/orchestrator.ts --once",
    "ralph": "./scripts/ralph.sh",
    "orchestrate:dry-run": "bun run scripts/orchestrator.ts --once --dry-run",
    "orchestrate:plugin": "bun run scripts/orchestrator.ts --workflow WORKFLOW.plugin.md",
    "orchestrate:plugin:once": "bun run scripts/orchestrator.ts --workflow WORKFLOW.plugin.md --once",
    "orchestrate:plugin:dry-run": "bun run scripts/orchestrator.ts --workflow WORKFLOW.plugin.md --once --dry-run",
    "orchestrate:supervisor": "bun run scripts/orchestrator-supervisor.ts run",
    "orchestrate:supervisor:start": "bun run scripts/orchestrator-supervisor.ts start",
    "orchestrate:supervisor:status": "bun run scripts/orchestrator-supervisor.ts status",
    "orchestrate:supervisor:stop": "bun run scripts/orchestrator-supervisor.ts stop",
    "orchestrate:supervisor:plugin": "bun run scripts/orchestrator-supervisor.ts run --workflow WORKFLOW.plugin.md --name plugin",
    "orchestrate:supervisor:start:plugin": "bun run scripts/orchestrator-supervisor.ts start --workflow WORKFLOW.plugin.md --name plugin",
    "orchestrate:supervisor:status:plugin": "bun run scripts/orchestrator-supervisor.ts status --workflow WORKFLOW.plugin.md --name plugin",
    "orchestrate:supervisor:stop:plugin": "bun run scripts/orchestrator-supervisor.ts stop --workflow WORKFLOW.plugin.md --name plugin",
    "orchestrate:launchd:install:plugin": "bun run scripts/install-launchd.ts --workflow WORKFLOW.plugin.md --name plugin"
  },
  "dependencies": {
    "@mahilo/policy-core": "workspace:*",
    "hono": "^4.7.0",
    "drizzle-orm": "^0.38.0",
    "@hono/zod-validator": "^0.4.0",
    "zod": "^3.24.0",
    "nanoid": "^5.0.9",
    "@node-rs/argon2": "^2.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.2",
    "drizzle-kit": "^0.30.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "eslint": "^9.19.0",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "prettier": "^3.4.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
